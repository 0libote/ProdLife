{
  "name": "prodlife",
  "version": "1.1.0",
  "description": "An all-in-one daily productivity system for Obsidian.",
  "main": "main.js",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun esbuild.config.mjs",
    "build": "tsc --noEmit && bun esbuild.config.mjs production",
    "lint": "eslint .",
    "test": "rm -rf .test-build && esbuild test/core.test.ts --bundle --platform=node --format=esm --out-extension:.js=.mjs --outdir=.test-build && node --test .test-build/core.test.mjs",
    "check": "bun run test && bun run lint && bun run build",
    "version": "bun version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "daily-notes",
    "reminders",
    "productivity"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "obsidian": "^1.8.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
