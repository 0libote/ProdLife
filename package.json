{
  "name": "prodlife",
  "version": "1.0.0",
  "description": "An all-in-one daily productivity system for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "test": "rm -rf .test-build && esbuild test/core.test.ts --bundle --platform=node --format=esm --out-extension:.js=.mjs --outdir=.test-build && node --test .test-build/core.test.mjs",
    "check": "npm run test && npm run build",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "daily-notes", "reminders", "productivity"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.7.0"
  }
}
