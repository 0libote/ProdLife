{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "*": ["src/*"] },
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "lib": ["DOM", "ES2018"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}

